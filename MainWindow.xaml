<Window x:Class="TinyRDP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TinyRDP Multi-Session"
        Width="360" SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Tahoma" FontSize="12"
        Foreground="Black">

    <StackPanel Margin="16,14,16,16">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Image Source="assets/tinyrdp-icon.png"
                   Width="38" Height="38" VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <Image Source="assets/tinyrdp-wordmark.png"
                   Height="30" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </StackPanel>
        <TextBlock Text="Multiple isolated desktops for multi-account use."
                   Foreground="#555" Margin="0,0,0,12"/>

        <TextBlock x:Name="StatusText" FontWeight="Bold" Margin="0,0,0,6"/>
        <TextBlock x:Name="HintText" TextWrapping="Wrap" Foreground="#333"/>

        <StackPanel Orientation="Horizontal" Margin="0,14,0,0" VerticalAlignment="Center">
            <TextBlock Text="Instances:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="InstanceCountBox" Text="2" Width="40" Height="22"
                     VerticalContentAlignment="Center"
                     PreviewTextInput="DigitsOnly"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
            <Button x:Name="LaunchBtn" Content="Launch" Width="90" Height="26"
                    Margin="0,0,8,0" Click="Launch_Click"/>
            <Button x:Name="RepairBtn" Content="Repair setup" Width="110" Height="26"
                    Click="Repair_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
